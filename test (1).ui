  <property name="styleSheet">
   <string notr="true">
QMainWindow {
    background-color: #1b212c;
}
QWidget#centralwidget {
    background-color: #1b212c;
}
QGroupBox {
    background-color: #232b38;
    border: 1px solid #333e4f;
    border-radius: 8px;
    margin-top: 16px;
    padding: 16px 12px 12px 12px;
    font-size: 11pt;
    font-weight: 600;
    color: #d7e2ee;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    top: -2px;
    padding: 0 6px;
    color: #6fd3c7;
}
QLabel {
    color: #b9c6d6;
    font-size: 10pt;
    background: transparent;
}
QLabel#titleLabel {
    color: #e6edf5;
    font-size: 15pt;
    font-weight: 700;
}
QLabel#windows_path {
    color: #8fd3ff;
    font-size: 10pt;
    padding: 4px 0;
}
QSpinBox, QComboBox {
    background-color: #151b24;
    color: #e6edf5;
    border: 1px solid #3a4457;
    border-radius: 5px;
    padding: 4px 6px;
    min-height: 22px;
}
QSpinBox:focus, QComboBox:focus {
    border: 1px solid #38bdf8;
}
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView {
    background-color: #1a212c;
    color: #e6edf5;
    selection-background-color: #2c4a5e;
    border: 1px solid #3a4457;
    outline: none;
}
QCheckBox { color: #d7e2ee; spacing: 8px; }
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid #3a4457;
    border-radius: 3px;
    background: #151b24;
}
QCheckBox::indicator:checked {
    background-color: #38bdf8;
    border: 1px solid #38bdf8;
}
QPushButton {
    background-color: #2b3648;
    color: #e6edf5;
    border: 1px solid #3a4457;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: 600;
}
QPushButton:hover { background-color: #34415a; border: 1px solid #4a5a75; }
QPushButton:pressed { background-color: #202a38; }
QPushButton#btn_r { background-color: #6b2020; border: 1px solid #b23a3a; color: #ffe4e4; }
QPushButton#btn_r:hover { background-color: #832727; }
QPushButton#btn_g { background-color: #1f5a34; border: 1px solid #3ab26a; color: #e4ffe9; }
QPushButton#btn_g:hover { background-color: #266f40; }
QPushButton#btn_b { background-color: #1d3f78; border: 1px solid #3a6fc2; color: #e4ecff; }
QPushButton#btn_b:hover { background-color: #244d91; }
QPushButton#btn_w { background-color: #3a4457; border: 1px solid #6b788f; color: #ffffff; }
QPushButton#btn_w:hover { background-color: #48546b; }
QPushButton#btn_bk { background-color: #10141b; border: 1px solid #3a4457; color: #b9c6d6; }
QPushButton#btn_bk:hover { background-color: #191f29; }
QPushButton#btn_off { background-color: #6b2020; border: 1px solid #9a2f2f; }
QPushButton#btn_off:hover { background-color: #832727; }
QPushButton#btn_choose_folder { background-color: #1d4f78; border: 1px solid #2f7cb8; text-align: left; padding: 10px 14px; }
QPushButton#btn_choose_folder:hover { background-color: #24618f; }
QFrame#colorRow {
    background-color: #202836;
    border: 1px solid #333e4f;
    border-radius: 8px;
}
QSlider::groove:horizontal {
    height: 6px;
    background: #151b24;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #38bdf8;
    width: 16px;
    margin: -6px 0;
    border-radius: 8px;
}
QSlider::sub-page:horizontal {
    background: #2c6a86;
    border-radius: 3px;
}
QMenuBar {
    background-color: #1b212c;
    color: #d7e2ee;
}
QStatusBar {
    background-color: #1b212c;
    color: #8797ab;
}
</string>
