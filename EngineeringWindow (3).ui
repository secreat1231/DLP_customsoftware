  <property name="styleSheet">
   <string notr="true">
QWidget#Form {
    background-color: #1b212c;
}
QGroupBox {
    background-color: #232b38;
    border: 1px solid #333e4f;
    border-radius: 8px;
    margin-top: 16px;
    padding: 16px 12px 12px 12px;
    font-size: 11pt;
    font-weight: 600;
    color: #d7e2ee;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    top: -2px;
    padding: 0 6px;
    color: #6fd3c7;
}
QLabel {
    color: #b9c6d6;
    font-size: 10pt;
    background: transparent;
}
QLabel#bannerLabel {
    background-color: #3a2a1a;
    color: #ffb454;
    border: 1px solid #6b4a22;
    border-radius: 6px;
    padding: 10px 16px;
    font-size: 12pt;
    font-weight: 700;
}
QSpinBox, QComboBox {
    background-color: #151b24;
    color: #e6edf5;
    border: 1px solid #3a4457;
    border-radius: 5px;
    padding: 4px 6px;
    min-height: 22px;
    font-size: 10pt;
    font-weight: 400;
    selection-background-color: #38bdf8;
}
QSpinBox:focus, QComboBox:focus {
    border: 1px solid #38bdf8;
}
QSpinBox[channel=&quot;r&quot;] { border: 1px solid #7a2d2d; }
QSpinBox[channel=&quot;r&quot;]:focus { border: 1px solid #ef4444; }
QSpinBox[channel=&quot;g&quot;] { border: 1px solid #245c34; }
QSpinBox[channel=&quot;g&quot;]:focus { border: 1px solid #22c55e; }
QSpinBox[channel=&quot;b&quot;] { border: 1px solid #24417a; }
QSpinBox[channel=&quot;b&quot;]:focus { border: 1px solid #3b82f6; }
QComboBox::drop-down { border: none; width: 22px; }
QComboBox QAbstractItemView {
    background-color: #1a212c;
    color: #e6edf5;
    selection-background-color: #2c4a5e;
    border: 1px solid #3a4457;
    outline: none;
}
QCheckBox { color: #d7e2ee; spacing: 8px; padding: 2px 0; }
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #3a4457;
    border-radius: 3px;
    background: #151b24;
}
QCheckBox::indicator:checked {
    background-color: #38bdf8;
    border: 1px solid #38bdf8;
}
QPushButton {
    background-color: #2b3648;
    color: #e6edf5;
    border: 1px solid #3a4457;
    border-radius: 6px;
    padding: 6px 16px;
    font-weight: 600;
    font-size: 10pt;
}
QPushButton:hover { background-color: #34415a; border: 1px solid #4a5a75; }
QPushButton:pressed { background-color: #202a38; }
QPushButton#btn_record { background-color: #16645a; border: 1px solid #1f8f7f; font-size: 13pt; }
QPushButton#btn_record:hover { background-color: #1a7a6c; }
QPushButton#btn_delete { background-color: #6b2020; border: 1px solid #9a2f2f; font-size: 13pt; }
QPushButton#btn_delete:hover { background-color: #832727; }
QPushButton#btn_send { background-color: #1d4f78; border: 1px solid #2f7cb8; }
QPushButton#btn_send:hover { background-color: #24618f; }
QTableWidget {
    background-color: #151b24;
    alternate-background-color: #1c2330;
    gridline-color: #313c4d;
    color: #e6edf5;
    border: 1px solid #333e4f;
    border-radius: 6px;
    selection-background-color: #2c4a5e;
    selection-color: #ffffff;
}
QHeaderView::section {
    background-color: #232b38;
    color: #9fb0c3;
    padding: 6px;
    border: none;
    border-bottom: 2px solid #38bdf8;
    font-weight: 600;
}
QSlider::groove:horizontal {
    height: 6px;
    background: #151b24;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #38bdf8;
    width: 16px;
    margin: -6px 0;
    border-radius: 8px;
}
QSlider::sub-page:horizontal {
    background: #2c6a86;
    border-radius: 3px;
}
</string>
